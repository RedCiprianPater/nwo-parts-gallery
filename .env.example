# NWO Parts Gallery — Environment Variables
# Copy to .env and fill in your values

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nwo:nwopass@localhost:5432/nwo_gallery
# For sync operations (Alembic migrations):
SYNC_DATABASE_URL=postgresql://nwo:nwopass@localhost:5432/nwo_gallery

# ── Blob Storage (S3-compatible) ───────────────────────────────────────────────
STORAGE_BACKEND=minio                  # s3 | minio | r2 | local
STORAGE_BUCKET=nwo-parts
STORAGE_ENDPOINT_URL=http://localhost:9000   # MinIO local; leave blank for AWS S3
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=password123
AWS_REGION=us-east-1                   # Required for AWS S3; ignored for MinIO

# For Cloudflare R2:
# STORAGE_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# Public URL base for file downloads (CDN or direct)
STORAGE_PUBLIC_URL=http://localhost:9000/nwo-parts

# ── Embeddings (for semantic search) ──────────────────────────────────────────
EMBEDDING_PROVIDER=openai              # openai | ollama | none
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=1536             # 1536 for text-embedding-3-small, 768 for nomic

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001
API_KEY=                               # Master API key (leave blank = open)
CORS_ORIGINS=*

# ── Gallery ────────────────────────────────────────────────────────────────────
GALLERY_TITLE=NWO Robotics Parts Gallery
GALLERY_BASE_URL=http://localhost:8001

# ── Agent Identity ─────────────────────────────────────────────────────────────
AGENT_KEY_ALGORITHM=ed25519            # ed25519 | rsa
MAX_PARTS_PER_AGENT=1000
MAX_FILE_SIZE_MB=100

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
